# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug
CORS_ORIGIN=*

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hubspot_bot
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_SIZE=10

# Ollama (Local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_TEMPERATURE=0.7
OLLAMA_MAX_TOKENS=1024

# HubSpot (Private App Token - approach simple)
# Ve a Settings > Integrations > Private Apps y crea un token con scopes: crm.objects.contacts.write, crm.objects.contacts.read
HUBSPOT_ACCESS_TOKEN=

# HubSpot OAuth (recomendado para producción)
# Crea una App en https://developers.hubspot.com/ > Create App
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_REDIRECT_URI=http://localhost:3000/oauth/callback
HUBSPOT_REFRESH_TOKEN=

# WhatsApp - ruta donde se guarda la sesión
WHATSAPP_SESSION_PATH=./whatsapp-session

# Configuración del negocio
BUSINESS_NAME=NeoWeb Studio
BUSINESS_SERVICES=Desarrollo web, landing pages, automatización de procesos

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30
